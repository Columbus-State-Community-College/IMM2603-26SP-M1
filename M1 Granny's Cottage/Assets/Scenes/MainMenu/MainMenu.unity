  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'Granny has been living her golden years at her cottage in peace for decades.
    That is, until recently when some monstrous businessmen showed up in her front
    yard one day droning on about "lucrative springwater opportunities" and trying
    to get Granny to sign over her property. Granny told the men her home was not
    for sale, but the men wouldn''t take no for an answer, and began trying to force
    Granny out.


    Not about to let some self-important capitalist wage-chasing
    demons bully her out of her peaceful life, Granny takes up her trusty hammer,
    ready to fight day and night to keep her land.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 227e84dfdfdf5104ba492b1e5d0b14ba, type: 2}
  m_sharedMaterial: {fileID: -9053434952393099548, guid: 227e84dfdfdf5104ba492b1e5d0b14ba, type: 2}
